# ─── DATABASE ───────────────────────────────────────────────
DATABASE_URL=postgresql://empleabilidad_user:secret@db:5432/empleabilidad_db
DATABASE_URL_TEST=postgresql://empleabilidad_user:secret@db:5432/empleabilidad_test
# ─── JWT ────────────────────────────────────────────────────
SECRET_KEY=changeme-use-openssl-rand-hex-32-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# ─── APP ────────────────────────────────────────────────────
ENVIRONMENT=development
DEBUG=true
APP_NAME=Sistema de Empleabilidad
APP_VERSION=1.0.0

# ─── CORS ───────────────────────────────────────────────────
ALLOWED_ORIGINS=["http://localhost:8501","http://127.0.0.1:8501"]

# ─── RATE LIMITING ──────────────────────────────────────────
RATE_LIMIT_LOGIN=10/minute
RATE_LIMIT_API=100/minute

# ─── EMAIL ──────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@tudominio.com
SMTP_PASSWORD=smtp_password
SMTP_FROM=noreply@tudominio.com

# ─── FRONTEND ───────────────────────────────────────────────
API_BASE_URL=http://localhost:8000
